# === FreshRSS + PostgreSQL ===
POSTGRES_DB=freshrss
POSTGRES_USER=freshrss
POSTGRES_PASSWORD=CHANGEME_use_a_real_password

FRESHRSS_PORT=8080

# === FreshRSS API (set these after completing FreshRSS setup wizard) ===
FRESHRSS_API_URL=http://freshrss/api/greader.php
FRESHRSS_API_USER=shawn
FRESHRSS_API_PASSWORD=your_api_password_here

# === Anthropic API (for daily digest) ===
ANTHROPIC_API_KEY=sk-ant-CHANGEME

# === Digest email settings (Fastmail) ===
DIGEST_SMTP_HOST=smtp.fastmail.com
DIGEST_SMTP_PORT=587
DIGEST_SMTP_USER=shawn@shawnsquire.me
DIGEST_SMTP_PASSWORD=your_fastmail_app_password
DIGEST_TO_EMAIL=shawn@shawnsquire.me

# === Interest profile (or edit config/interest-profile.md for the full version) ===
DIGEST_INTERESTS="AI/ML in enterprise software, people analytics, AWS infrastructure, self-hosted tooling, indie game dev, MTG Commander, TTRPG design, photography software"
DIGEST_ANTI_INTERESTS="crypto, mainstream consumer gadget reviews, marketing/growth hacking, SEO content"
